{
  "name": "razor3d",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Three.js application starter for Razor3D.",
  "keywords": [
    "three",
    "threejs",
    "vite",
    "typescript",
    "webgl",
    "3d"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "lint:fix": "eslint . --ext .ts,.tsx,.js --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,scss,md,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,scss,md,html}\"",
    "ci": "npm run type-check && npm run lint && npm run test && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "lit-html": "^3.3.2",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.1.1",
    "@stylistic/eslint-plugin": "^5.2.2",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^22.0.0",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-prettier": "^5.2.0",
    "husky": "^9.1.0",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "sass": "^1.77.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}